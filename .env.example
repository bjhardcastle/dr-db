DR_DB_STORAGE_ROOT=/home/ben.hardcastle/dr-db

# Set these from `id -u` and `id -g` on the VM. Do not leave them as 1000
# unless those commands return 1000.
DR_DB_CONTAINER_UID=1000
DR_DB_CONTAINER_GID=1000

DR_DB_POSTGRES_USER=svc_neuropix
DR_DB_POSTGRES_PASSWORD=replace-me
DR_DB_POSTGRES_DB=dr_db
DR_DB_POSTGRES_HOST_PORT=7500

MATHESAR_HOST_PORT=7000
MATHESAR_DOMAIN_NAME=http://dr-db,http://localhost,http://127.0.0.1
MATHESAR_ALLOWED_HOSTS=dr-db,localhost,127.0.0.1,[::1]
